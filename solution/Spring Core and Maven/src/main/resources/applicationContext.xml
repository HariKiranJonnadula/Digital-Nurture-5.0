<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Define BookRepository bean (Exercise 1) -->
    <bean id="bookRepository" class="app.BookRepository" />

    <!-- Define BookService bean and wire BookRepository via Setter Injection (Exercise 2) -->
    <bean id="bookService" class="app.BookService">
        <property name="bookRepository" ref="bookRepository" />
    </bean>

</beans>
